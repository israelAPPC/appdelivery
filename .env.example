# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase CLI (gerenciamento/migrations automáticas — token pessoal, não é chave de runtime do app)
# Gere em https://supabase.com/dashboard/account/tokens — NUNCA vai para produção/Vercel
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=

# Gemini (tarefas auxiliares de baixo custo — opcional)
GEMINI_API_KEY=

# OpenRouteService (geocodificação e cálculo de distância para frete — gratuito, sem cartão)
# Gere a chave em https://openrouteservice.org/dev/#/signup
OPENROUTESERVICE_API_KEY=

# Web Push (notificação nativa, gerar par de chaves com: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
